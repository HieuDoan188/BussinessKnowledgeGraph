{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business OS Handbook — Ontology",
  "version": "1.0.0",
  "description": "Formal ontology defining entity types, relation types, and constraints for the Business Knowledge Graph.",

  "entity_types": {
    "Module": {
      "description": "A knowledge module in the handbook (e.g. S01-corporate-strategy)",
      "id_prefix": "MOD",
      "id_pattern": "^[A-Z]{1,3}[0-9]{2}$",
      "required_properties": ["code", "name", "domain", "status"],
      "optional_properties": ["level", "learning_time_hours", "prerequisites", "related_modules", "tags"]
    },
    "Framework": {
      "description": "A named methodology, model or analytical tool used in business (e.g. Porter Five Forces, SCOR, OKR)",
      "id_prefix": "FW",
      "required_properties": ["label", "origin"],
      "optional_properties": ["author", "year", "version", "aliases", "domain_tags"]
    },
    "Concept": {
      "description": "A fundamental business concept or term (e.g. Working Capital, Bullwhip Effect, CAC)",
      "id_prefix": "CON",
      "required_properties": ["label", "definition_short"],
      "optional_properties": ["aliases", "domain_tags", "formula"]
    },
    "Standard": {
      "description": "An accounting, quality or technical standard (e.g. IFRS 15, ISO 9001, VAS 02)",
      "id_prefix": "STD",
      "required_properties": ["label", "issuing_body"],
      "optional_properties": ["scope", "aliases", "effective_date", "jurisdiction"]
    },
    "Law": {
      "description": "A legal statute, decree or regulation (e.g. BLLĐ 2019, Luật DN 2020, NĐ 13/2023)",
      "id_prefix": "LAW",
      "required_properties": ["label", "jurisdiction", "number"],
      "optional_properties": ["effective_date", "aliases", "domain_tags", "issuing_body"]
    },
    "Company": {
      "description": "A company referenced as a case study or real-world example (e.g. Vinamilk, FPT, Samsung)",
      "id_prefix": "CO",
      "required_properties": ["label", "country"],
      "optional_properties": ["industry", "aliases", "type"]
    }
  },

  "relation_types": {
    "prerequisite_of": {
      "description": "Module A must be studied before Module B",
      "from": ["Module"],
      "to": ["Module"],
      "inverse": "has_prerequisite",
      "cardinality": "many-to-many"
    },
    "relates_to": {
      "description": "Module A is topically connected to Module B (non-hierarchical)",
      "from": ["Module"],
      "to": ["Module"],
      "inverse": "relates_to",
      "cardinality": "many-to-many",
      "symmetric": true
    },
    "implements": {
      "description": "Module teaches or applies a Framework or Standard",
      "from": ["Module"],
      "to": ["Framework", "Standard"],
      "inverse": "implemented_in",
      "cardinality": "many-to-many"
    },
    "regulated_by": {
      "description": "Module content is governed or constrained by a Law or Standard",
      "from": ["Module"],
      "to": ["Law", "Standard"],
      "inverse": "regulates",
      "cardinality": "many-to-many"
    },
    "used_in": {
      "description": "A Framework or Concept appears/is applied in a Module",
      "from": ["Framework", "Concept"],
      "to": ["Module"],
      "inverse": "uses",
      "cardinality": "many-to-many"
    },
    "defines": {
      "description": "A Module is the primary definer of a Concept",
      "from": ["Module"],
      "to": ["Concept"],
      "inverse": "defined_in",
      "cardinality": "one-to-many"
    },
    "exemplified_by": {
      "description": "A concept, framework or law is illustrated by a real Company case study",
      "from": ["Module", "Framework", "Concept", "Law"],
      "to": ["Company"],
      "inverse": "exemplifies",
      "cardinality": "many-to-many"
    },
    "supersedes": {
      "description": "A Law or Standard replaces an older version",
      "from": ["Law", "Standard"],
      "to": ["Law", "Standard"],
      "inverse": "superseded_by",
      "cardinality": "one-to-one"
    }
  },

  "domain_taxonomy": {
    "01-foundation":       { "code_prefix": "F",  "label": "Foundation" },
    "02-business":         { "code_prefix": "B",  "label": "Business Model" },
    "03-strategy":         { "code_prefix": "S",  "label": "Strategy" },
    "04-marketing":        { "code_prefix": "MK", "label": "Marketing" },
    "05-sales":            { "code_prefix": "SA", "label": "Sales" },
    "06-finance":          { "code_prefix": "FI", "label": "Finance" },
    "07-accounting":       { "code_prefix": "AC", "label": "Accounting" },
    "08-law":              { "code_prefix": "LW", "label": "Law" },
    "09-tax":              { "code_prefix": "TX", "label": "Tax" },
    "10-hr":               { "code_prefix": "HR", "label": "Human Resources" },
    "11-operations":       { "code_prefix": "OP", "label": "Operations" },
    "12-logistics":        { "code_prefix": "LG", "label": "Logistics & SCM" },
    "13-manufacturing":    { "code_prefix": "MF", "label": "Manufacturing" },
    "14-erp":              { "code_prefix": "ERP","label": "ERP Systems" },
    "15-crm":              { "code_prefix": "CRM","label": "CRM" },
    "16-data":             { "code_prefix": "DA", "label": "Data & BI" },
    "17-ai":               { "code_prefix": "AI", "label": "AI & Digital" },
    "18-consulting":       { "code_prefix": "CN", "label": "Consulting" },
    "19-governance":       { "code_prefix": "GV", "label": "Governance" },
    "20-corporate-events": { "code_prefix": "CE", "label": "Corporate Events" },
    "21-business-types":   { "code_prefix": "BT", "label": "Business Types" }
  }
}
